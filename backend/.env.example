# Database: SQLite (default) or PostgreSQL
# SQLite: sqlite+aiosqlite:///./data/study_assistant.db
# PostgreSQL: postgresql+asyncpg://postgres:postgres@localhost:5432/study_assistant
DATABASE_URL=sqlite+aiosqlite:///./data/study_assistant.db

# Auth
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Qdrant (vector store)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Embedding (for Qdrant vector search)
# Models: all-MiniLM-L6-v2 (384d), BAAI/bge-small-zh-v1.5 (512d), BAAI/bge-m3 (1024d)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# File upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
